APP_NAME="Boels CORE Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://databasehub.sorai.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=nl

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=deb2003831_hub_database_boels
DB_USERNAME=deb2003831_hub_database_boels
DB_PASSWORD=

# Sessie & cache — voor shared hosting bewust file/database, niet redis
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Boels CORE specific
BOELS_BRAND_COLOR="#FF6600"
BOELS_BRAND_TEXT_COLOR="#FFFFFF"

# Super Admin bootstrap (alleen op eerste seed gebruikt)
SUPERADMIN_NAME="Wim Groeneweg"
SUPERADMIN_EMAIL=w_groeneweg@hotmail.com
SUPERADMIN_PASSWORD=

# Mail (Antagonist SMTP — invullen na aanmaak mailbox)
MAIL_MAILER=smtp
MAIL_HOST=smtp.antagonist.nl
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@sorai.nl"
MAIL_FROM_NAME="${APP_NAME}"
